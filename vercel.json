{
  "rewrites": [
    {
      "source": "/api/get_barcode",
      "destination": "/api/get_barcode.py"
    },
    {
      "source": "/api/warm_next",
      "destination": "/api/warm_next.py"
    },
    {
      "source": "/api/warm_done",
      "destination": "/api/warm_done.py"
    },
    {
      "source": "/api/warm_status",
      "destination": "/api/warm_status.py"
    },
    {
      "source": "/api/warm_tick",
      "destination": "/api/warm_tick.py"
    },
    {
      "source": "/api/sso_debug",
      "destination": "/api/sso_debug.py"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "functions": {
    "api/get_barcode.py": {
      "maxDuration": 60
    },
    "api/warm_next.py": {
      "maxDuration": 30
    },
    "api/warm_done.py": {
      "maxDuration": 30
    },
    "api/warm_status.py": {
      "maxDuration": 30
    },
    "api/warm_tick.py": {
      "maxDuration": 60
    }
  }
}
